<Project>
    <!--
        Local override. The repository-root Directory.Build.props sets
        TargetFrameworks=net8.0;net9.0;net10.0 for every project; BenchmarkDotNet
        auto-generates a host project inside this project's bin folder which
        inherits that property and then fails to restore because this project
        is net10.0 only. Pinning the property here (a) keeps this project at
        net10.0, and (b) constrains the BDN auto-generated project to net10.0
        as well.
    -->
    <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))"/>
    <PropertyGroup>
        <TargetFrameworks>net10.0</TargetFrameworks>
    </PropertyGroup>
</Project>
